# 生产环境变量 — GitHub Pages 部署 (cater.yyc3.vip)
# Vite 构建时注入,需以 VITE_ 前缀

# 部署基路径(自定义域名从根提供)
VITE_BASE_PATH=/

# 后端 API 基址
# 后端就绪后改为真实地址,例如 https://api.yyc3.vip/api/v1
# 当前留空 → 前端回退到 http://localhost:3006/api/v1(仅本地开发可用)
# 也可在 GitHub 仓库 Settings → Secrets 配置 VITE_API_BASE_URL secret 覆盖
VITE_API_BASE_URL=

# 应用标题
VITE_APP_TITLE=YYC³餐饮管理后台
